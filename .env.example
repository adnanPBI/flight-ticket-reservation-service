APP_NAME="OTA Flight Booking"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ota_flight_booking
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=reverb

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=ota-local-app
REVERB_APP_KEY=local-reverb-key
REVERB_APP_SECRET=local-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

DUFFEL_ACCESS_TOKEN=
DUFFEL_ENV=sandbox

AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

# Flight provider phase 2/3
FLIGHT_PROVIDER=duffel
FLIGHT_MOCK_MODE=true
FLIGHT_OFFER_TTL_MINUTES=45
FLIGHT_MAX_RESULTS_FOR_MVP=30

# Phase 7 provider order finalization safety gates
# Keep false unless Duffel sandbox/production credentials, balance/payment method, and commercial approval are confirmed.
FLIGHT_REAL_ORDER_FINALIZATION=false
FLIGHT_AUTO_REFUND_FAILED_BOOKINGS=false
FLIGHT_TICKETING_SYNC_ENABLED=true

DUFFEL_BASE_URL=https://api.duffel.com
DUFFEL_ACCESS_TOKEN=
DUFFEL_VERSION=v2
DUFFEL_TIMEOUT=30
AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_TIMEOUT=30

# Phase 4 offer revalidation
FLIGHT_OFFER_REVALIDATION_ENABLED=true
FLIGHT_FAIL_ON_EXPIRED_OFFER=true

# Stripe Phase 6 safe defaults
STRIPE_MOCK_MODE=true
STRIPE_KEY=pk_test_mock
STRIPE_SECRET=sk_test_mock
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
STRIPE_DISPATCH_CONFIRM_JOB=true

# Phase 9 pricing controls
PRICING_MINIMUM_TOTAL_MINOR=100
PRICING_DEFAULT_CURRENCY=USD
PRICING_MAX_PERCENTAGE_DISCOUNT=30

# Phase 10 support chat
CHAT_PUBLIC_CHANNELS_FOR_MVP=true

# Phase 12 cleanup/scheduler defaults
CLEANUP_EXPIRED_SEARCH_LIMIT=500
CLEANUP_RAW_OFFER_PAYLOAD_RETENTION_DAYS=14
CLEANUP_PROVIDER_LOG_PAYLOAD_RETENTION_DAYS=30
CLEANUP_ABANDONED_PAYMENT_MINUTES=120
CLEANUP_PENDING_TICKETING_ALERT_MINUTES=60

# Phase 13 security/audit hardening
FORCE_HTTPS=false
SECURITY_HEADERS_ENABLED=true
SECURITY_HSTS_ENABLED=false
SECURITY_CSP_ENABLED=true
SECURITY_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
SECURITY_PERMISSIONS_POLICY="camera=(), microphone=(), geolocation=(), payment=(self)"
SENSITIVE_DATA_MASKING=true
RATE_LIMIT_FLIGHT_SEARCH_PER_MINUTE=30
RATE_LIMIT_CHECKOUT_PER_MINUTE=20
RATE_LIMIT_PAYMENT_PER_MINUTE=20
RATE_LIMIT_WEBHOOK_PER_MINUTE=120
RATE_LIMIT_CHAT_PER_MINUTE=60
RATE_LIMIT_MANAGE_BOOKING_PER_MINUTE=10
RATE_LIMIT_ADMIN_SENSITIVE_PER_MINUTE=30

# Phase 14 cPanel VPS deployment
CPANEL_USER=your_cpanel_user
CPANEL_APP_PATH=/home/your_cpanel_user/ota
CPANEL_PUBLIC_PATH=/home/your_cpanel_user/public_html
SUPERVISOR_LOG_PATH=/home/your_cpanel_user/ota/storage/logs
REVERB_PUBLIC_PORT=8080
