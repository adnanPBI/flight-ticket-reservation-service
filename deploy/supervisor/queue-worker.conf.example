[program:ota-queue-default]
process_name=%(program_name)s_%(process_num)02d
command=/usr/local/bin/php /home/CPANEL_USER/ota/artisan queue:work redis --queue=default,bookings,mail --sleep=3 --tries=3 --max-time=3600
directory=/home/CPANEL_USER/ota
autostart=true
autorestart=true
user=CPANEL_USER
numprocs=2
redirect_stderr=true
stdout_logfile=/home/CPANEL_USER/ota/storage/logs/queue-worker.log
stopwaitsecs=3600
