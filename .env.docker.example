APP_NAME="OTA Flight Booking"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ota_db
DB_USERNAME=ota_user
DB_PASSWORD=ota_password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=ota-local
REVERB_APP_KEY=ota-local-key
REVERB_APP_SECRET=ota-local-secret
REVERB_HOST=localhost
REVERB_PORT=8081
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_MOCK_MODE=true
STRIPE_DISPATCH_CONFIRM_JOB=true
STRIPE_KEY=pk_test_replace_me
STRIPE_SECRET=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

FLIGHT_MOCK_MODE=true
FLIGHT_DEFAULT_PROVIDER=duffel
FLIGHT_REAL_ORDER_FINALIZATION=false
FLIGHT_AUTO_REFUND_FAILED_BOOKINGS=false
DUFFEL_ACCESS_TOKEN=
DUFFEL_ENV=sandbox
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test

SECURITY_REQUIRE_HTTPS=false
SECURITY_HEALTH_CHECK_TOKEN=local-health-token
